# Local dev — Docker Postgres (see docker-compose.yml)
# Run `npm run db:up` first to start the container.
DATABASE_URL=postgresql://broadcast:broadcast@localhost:5432/broadcast_dev

AUTH_SECRET=
NEXTAUTH_URL=http://localhost:4321

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign-In — leave ENABLE_APPLE_SIGNIN=false until real domain is provisioned
ENABLE_APPLE_SIGNIN=false
APPLE_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Session persistence — flip to true once Postgres is reachable.
# CI sets this to false (no DB on runners). Smoke tests work either way.
ENABLE_SESSION_PERSISTENCE=true

# Beta access gate. When REQUIRE_INVITE_CODE=true (default), POST /api/auth/signup
# requires a valid `inviteCode` field that matches one of the comma-separated codes
# in BETA_INVITE_CODES. Match is case-insensitive, whitespace-trimmed.
REQUIRE_INVITE_CODE=true
BETA_INVITE_CODES=academy2026,daniel,early-access

# Optional: PIN of a demo game pre-loaded for the public landing page.
# When set, the marketing landing renders a "Try a demo" CTA pointing at /play/<pin>.
NEXT_PUBLIC_DEMO_PIN=

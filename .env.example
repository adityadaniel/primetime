# Local dev — Docker Postgres (see docker-compose.yml)
# Run `npm run db:up` first to start the container.
DATABASE_URL=postgresql://primetime:primetime@localhost:5432/primetime_dev

AUTH_SECRET=

# ====================================================================
# Public origin — pick ONE of the two profiles below depending on how
# you're running the app. The setup script (scripts/setup.sh) writes
# these for you on first install; this file documents the shape for
# manual setup.
# ====================================================================

# (a) LOCAL DEV — only reached at http://localhost:4321
NEXTAUTH_URL=http://localhost:4321
NEXT_PUBLIC_SITE_URL=http://localhost:4321

# (b) WORKSHOP / TUNNEL — reached at https://live.<your-domain> via
#     Cloudflare Tunnel. Uncomment + replace the hostname, and comment
#     out (a) above. AUTH_TRUST_HOST=true is REQUIRED for Auth.js to
#     honor the X-Forwarded-* headers Cloudflare sets — without it,
#     sign-in callbacks bounce back to localhost.
# NEXTAUTH_URL=https://live.theprimetime.id
# NEXT_PUBLIC_SITE_URL=https://live.theprimetime.id
# AUTH_TRUST_HOST=true

# ====================================================================
# OSS ⇄ SaaS config surface (MID-214). The same codebase ships as OSS
# (no billing / email / OAuth / cloud uploads) or SaaS (full). Every
# flag below DEFAULTS to the OSS path — a fresh self-host needs NONE of
# them and never needs a SaaS provider account. Parsed in lib/config.ts;
# an invalid value or a selected provider missing its vars fails fast.
#
#   Flag             | Values                       | OSS default
#   -----------------+------------------------------+------------
#   AUTH_MODE        | password | password+oauth    | password
#   EMAIL_PROVIDER   | none | smtp | resend          | none
#   UPLOAD_PROVIDER  | local | s3 | uploadthing      | local
#   BILLING_ENABLED  | true | false                 | false
# ====================================================================

# Auth mode. OSS default `password` = local email + password (Credentials
# provider) only. Set `password+oauth` to additionally enable third-party
# providers such as Apple (each provider is still individually gated below).
AUTH_MODE=password

# Transactional email. OSS default `none` = no email sent. `smtp` requires
# SMTP_HOST/SMTP_PORT/SMTP_USER/SMTP_PASSWORD. `resend` requires RESEND_API_KEY.
EMAIL_PROVIDER=none
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# RESEND_API_KEY=

# Asset uploads. OSS default `local` = on-disk, no cloud account. `s3`
# requires S3_BUCKET/S3_REGION/S3_ACCESS_KEY_ID/S3_SECRET_ACCESS_KEY
# (S3-compatible, incl. Cloudflare R2). `uploadthing` requires UPLOADTHING_TOKEN.
UPLOAD_PROVIDER=local
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=
# UPLOADTHING_TOKEN=

# Billing. OSS default OFF — no Stripe/upgrade flow. Leave false to self-host.
BILLING_ENABLED=false

# Apple Sign-In — only takes effect when AUTH_MODE=password+oauth AND this is
# true. Leave false unless you have a real Apple Services ID, team, key, and
# provisioned domain; when enabled all four APPLE_* vars are required. The OSS
# default does not require Apple — local email/password works out of the box.
ENABLE_APPLE_SIGNIN=false
APPLE_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Session persistence — flip to true once Postgres is reachable.
# CI sets this to false (no DB on runners). Smoke tests work either way.
ENABLE_SESSION_PERSISTENCE=true

# Beta access gate. OSS default is OFF: signup is open for any deployment.
# Flip REQUIRE_INVITE_CODE=true and populate BETA_INVITE_CODES if you want
# to gate signups (e.g. private beta). Match is case-insensitive,
# whitespace-trimmed.
REQUIRE_INVITE_CODE=false
# Only used when REQUIRE_INVITE_CODE=true. Generate real codes; never reuse
# placeholders.
BETA_INVITE_CODES=

# Optional: PIN of a demo game pre-loaded for the public landing page.
# When set, the marketing landing renders a "Try a demo" CTA pointing at /play/<pin>.
NEXT_PUBLIC_DEMO_PIN=

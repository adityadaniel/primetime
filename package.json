{
  "name": "inputoutput",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx server.ts",
    "qa": "next dev --port 4322",
    "build": "prisma generate && next build",
    "start": "NODE_ENV=production tsx server.ts",
    "setup": "bash scripts/setup.sh",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "smoke": "tsx scripts/smoke.ts",
    "test": "TZ=UTC vitest run",
    "test:watch": "TZ=UTC vitest",
    "test:coverage": "TZ=UTC vitest run --coverage",
    "sounds:generate": "tsx scripts/generate-sounds.ts",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d --wait && prisma migrate dev",
    "db:logs": "docker compose logs -f postgres",
    "db:psql": "docker compose exec postgres psql -U inputoutput -d inputoutput_dev",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3",
    "nodemailer": "^7.0.0",
    "next": "^15.5.18",
    "next-auth": "^5.0.0-beta.31",
    "qrcode.react": "4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "socket.io": "4.8.1",
    "socket.io-client": "4.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "22.9.0",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "autoprefixer": "10.4.20",
    "jsdom": "^29.1.1",
    "postcss": "8.4.49",
    "prisma": "^6.19.3",
    "tailwindcss": "3.4.15",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.6",
    "wait-on": "^9.0.10"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}

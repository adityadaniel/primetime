            class="display-num mt-1"
            style="letter-spacing: -0.02em;"
          >
            INCORRECT
          </p>
        </div>
        <div
          class="grid grid-cols-2 gap-3 mt-5"
        >
          <div
            class="ink-border p-4 min-w-0 overflow-hidden"
            style="background: var(--bone);"
          >
            <span
              class="chyron opacity-70"
            >
              YOUR SCORE
            </span>
            <p
              class="display-num mt-1 ticker tabular-nums whitespace-nowrap"
            >
              0
            </p>
          </div>
          <div
            class="ink-border p-4 min-w-0 overflow-hidden"
            style="background: var(--bone);"
          >
            <span
              class="chyron opacity-70"
            >
              RANK
            </span>
            <p
              class="display-num mt-1 ticker tabular-nums whitespace-nowrap"
            >
              —
            </p>
          </div>
        </div>
        <div
          class="mt-5 ink-border p-4 flex items-center gap-4"
          style="background: var(--vermilion); color: var(--bone);"
        >
          <svg
            aria-hidden="true"
            height="42"
            viewBox="0 0 100 100"
            width="42"
          >
            <polygon
              fill="var(--bone)"
              points="50,10 92,86 8,86"
              stroke="var(--ink)"
              stroke-linejoin="miter"
              stroke-width="2"
            />
          </svg>
          <div>
            <span
              class="chyron"
              style="color: var(--bone); opacity: 0.85;"
            >
              CORRECT ANSWER
            </span>
            <p
              class="font-editorial text-xl"
            >
              Mercury
            </p>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
`;

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Tier {
  free
  pro
}

enum SessionStatus {
  active
  finished
  abandoned
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  emailVerified      DateTime?
  passwordHash       String?
  name               String?
  image              String?
  tier               Tier               @default(free)
  accounts           Account[]
  sessions           Session[]
  hostedSessions     GameSession[]
  wordCloudSessions  WordCloudSession[]
  qaSessions         QASession[]
  quizzes            Quiz[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Quiz {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  questions Question[]

  @@index([userId])
}

model Question {
  id           String   @id @default(cuid())
  quizId       String
  quiz         Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  ordinal      Int
  type         String
  text         String
  options      String[]
  correct      Int
  timeLimit    Int
  doublePoints Boolean  @default(false)
  imageUrl     String?

  @@unique([quizId, ordinal])
  @@index([quizId])
}

model GameSession {
  id               String          @id @default(cuid())
  pin              String          @unique
  hostUserId       String?
  hostUser         User?           @relation(fields: [hostUserId], references: [id], onDelete: SetNull)
  quizSnapshot     Json
  status           SessionStatus   @default(active)
  createdAt        DateTime        @default(now())
  startedAt        DateTime?
  endedAt          DateTime?
  finalLeaderboard Json?
  players          SessionPlayer[]
  answers          SessionAnswer[]

  @@index([hostUserId, createdAt])
  @@index([status])
}

model SessionPlayer {
  id         String      @id @default(cuid())
  sessionId  String
  session    GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  inGameId   String
  nickname   String
  joinedAt   DateTime    @default(now())
  finalScore Int         @default(0)
  finalRank  Int?

  @@unique([sessionId, inGameId])
  @@index([sessionId])
}

model SessionAnswer {
  id             String      @id @default(cuid())
  sessionId      String
  session        GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionIndex  Int
  playerInGameId String
  optionIndex    Int
  correct        Boolean
  msFromStart    Int
  awarded        Int
  createdAt      DateTime    @default(now())

  @@index([sessionId, questionIndex])
}

enum WordCloudStatus {
  LOBBY
  LIVE
  PAUSED
  ENDED
  ARCHIVED
}

model WordCloudSession {
  id              String                @id @default(cuid())
  pin             String                @unique
  prompt          String                @db.VarChar(200)
  wordsPerPlayer  Int                   @default(3)
  profanityFilter Boolean               @default(true)
  hostUserId      String?
  hostUser        User?                 @relation(fields: [hostUserId], references: [id], onDelete: SetNull)
  status          WordCloudStatus       @default(LOBBY)
  createdAt       DateTime              @default(now())
  startedAt       DateTime?
  endedAt         DateTime?
  players         WordCloudPlayer[]
  submissions     WordCloudSubmission[]
  moderation      WordCloudModeration[]

  @@index([hostUserId, createdAt])
  @@index([status])
}

model WordCloudPlayer {
  id          String                @id @default(cuid())
  sessionId   String
  session     WordCloudSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  nickname    String
  joinedAt    DateTime              @default(now())
  submissions WordCloudSubmission[]

  @@unique([sessionId, nickname])
  @@index([sessionId])
}

model WordCloudSubmission {
  id         String           @id @default(cuid())
  sessionId  String
  session    WordCloudSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  playerId   String
  player     WordCloudPlayer  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  rawText    String           @db.VarChar(40)
  normalized String           @db.VarChar(40)
  removed    Boolean          @default(false)
  removedAt  DateTime?
  createdAt  DateTime         @default(now())

  @@index([sessionId, normalized])
  @@index([sessionId, removed])
}

model WordCloudModeration {
  id         String           @id @default(cuid())
  sessionId  String
  session    WordCloudSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  hostUserId String?
  word       String
  reason     String
  createdAt  DateTime         @default(now())

  @@index([sessionId, createdAt])
}

enum QASessionStatus {
  OPEN
  CLOSED
  ENDED
  ARCHIVED
}

enum QAQuestionStatus {
  IN_REVIEW
  LIVE
  ANSWERED
  ARCHIVED
  DISMISSED
  WITHDRAWN
}

enum QAPrivacyMode {
  ANONYMOUS_BY_DEFAULT
  ALWAYS_ANONYMOUS
  NAMED_BY_DEFAULT
  NAME_REQUIRED
}

enum QAVoteType {
  UP
  DOWN
}

model QASession {
  id                        String              @id @default(cuid())
  pin                       String              @unique
  title                     String              @db.VarChar(100)
  description               String?             @db.VarChar(200)
  privacyMode               QAPrivacyMode       @default(ANONYMOUS_BY_DEFAULT)
  moderationEnabled         Boolean             @default(false)
  participantRepliesEnabled Boolean             @default(false)
  downvotesEnabled          Boolean             @default(false)
  questionCharLimit         Int                 @default(280)
  status                    QASessionStatus     @default(OPEN)
  // Live presentation state persisted so restart hydration (lib/qa-hydrate.ts)
  // can restore the room exactly. submissionsOpen is derived from status
  // (OPEN <-> open), so only voting needs its own column.
  votingOpen                Boolean             @default(true)
  // Pointer to the currently highlighted LIVE question. Plain column (no FK):
  // validated against question status on hydration.
  highlightedQuestionId     String?
  hostUserId                String?
  hostUser                  User?               @relation(fields: [hostUserId], references: [id], onDelete: SetNull)
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  endedAt                   DateTime?
  participants              QAParticipant[]
  questions                 QAQuestion[]
  labels                    QALabel[]
  moderationEvents          QAModerationEvent[]

  @@index([hostUserId, createdAt])
  @@index([status])
}

model QAParticipant {
  id          String       @id @default(cuid())
  sessionId   String
  session     QASession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  displayName String?
  joinedAt    DateTime     @default(now())
  questions   QAQuestion[]
  votes       QAVote[]
  replies     QAReply[]

  @@index([sessionId])
}

model QAQuestion {
  id                String              @id @default(cuid())
  sessionId         String
  session           QASession           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  // Participant linkage exists for personal state (withdraw/edit/own-question
  // views) only. Anonymous questions must never surface this linkage in
  // host-visible or export DTOs — see lib/qa-repo.ts projections.
  participantId     String?
  participant       QAParticipant?      @relation(fields: [participantId], references: [id], onDelete: SetNull)
  text              String              @db.VarChar(500)
  // Preserved verbatim the first time a host edits the question.
  originalText      String?             @db.VarChar(500)
  isAnonymous       Boolean             @default(true)
  // Public author name snapshot for named questions; null when anonymous.
  authorDisplayName String?
  status            QAQuestionStatus    @default(LIVE)
  submittedAt       DateTime            @default(now())
  approvedAt        DateTime?
  answeredAt        DateTime?
  archivedAt        DateTime?
  dismissedAt       DateTime?
  withdrawnAt       DateTime?
  updatedAt         DateTime            @updatedAt
  votes             QAVote[]
  replies           QAReply[]
  labels            QAQuestionLabel[]
  moderationEvents  QAModerationEvent[]

  @@index([sessionId, status])
  @@index([sessionId, submittedAt])
}

model QAVote {
  id            String        @id @default(cuid())
  questionId    String
  question      QAQuestion    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  participantId String
  participant   QAParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  type          QAVoteType    @default(UP)
  createdAt     DateTime      @default(now())

  @@unique([questionId, participantId])
  @@index([questionId])
}

model QALabel {
  id                    String            @id @default(cuid())
  sessionId             String
  session               QASession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name                  String            @db.VarChar(50)
  participantSelectable Boolean           @default(false)
  createdAt             DateTime          @default(now())
  questions             QAQuestionLabel[]

  @@unique([sessionId, name])
  @@index([sessionId])
}

model QAQuestionLabel {
  questionId String
  question   QAQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  labelId    String
  label      QALabel    @relation(fields: [labelId], references: [id], onDelete: Cascade)
  createdAt  DateTime   @default(now())

  @@id([questionId, labelId])
  @@index([labelId])
}

model QAReply {
  id            String         @id @default(cuid())
  questionId    String
  question      QAQuestion     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  // Null participantId + isHostReply=true marks a host reply.
  participantId String?
  participant   QAParticipant? @relation(fields: [participantId], references: [id], onDelete: SetNull)
  isHostReply   Boolean        @default(false)
  text          String         @db.VarChar(1000)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([questionId, createdAt])
}

model QAModerationEvent {
  id         String      @id @default(cuid())
  sessionId  String
  session    QASession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId String?
  question   QAQuestion? @relation(fields: [questionId], references: [id], onDelete: SetNull)
  hostUserId String?
  action     String
  reason     String?
  createdAt  DateTime    @default(now())

  @@index([sessionId, createdAt])
}
